# Environment context — drives SSL, security, and certificate handling
# Values: local | server
APP_ENV=local

# Traefik dashboard
# local: keep true — trusted environment, no restrictions needed
# server: set to false — do not expose the dashboard publicly; if needed, secure it behind a VPN or auth proxy
TRAEFIK_DASHBOARD_ENABLED=true

# Exposed ports
TRAEFIK_PORT_HTTP=80
TRAEFIK_PORT_DASHBOARD=8000
# TRAEFIK_PORT_HTTPS=443
