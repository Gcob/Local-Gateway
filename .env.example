# Environment context — drives SSL, security, and certificate handling
# Values: local | server
APP_ENV=local

# Shared Docker network name used by Traefik and all connected projects
DOCKER_NETWORK=local_gateway

# Traefik dashboard — disable in production
TRAEFIK_DASHBOARD_ENABLED=true

# Exposed ports
TRAEFIK_PORT_HTTP=80
TRAEFIK_PORT_DASHBOARD=8000
# TRAEFIK_PORT_HTTPS=443
